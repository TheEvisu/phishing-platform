{
  "name": "phishing-platform",
  "version": "0.0.1",
  "description": "NestJS monorepo for phishing simulation platform",
  "scripts": {
    "start:management": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register apps/management/src/main.ts",
    "start:simulation": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register apps/simulation/src/main.ts",
    "build:management": "tsc -p apps/management/tsconfig.app.json",
    "build:simulation": "tsc -p apps/simulation/tsconfig.app.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "mongoose": "^7.8.9",
    "nodemailer": "^7.0.6",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.0"
  }
}
